// Pro Optimization — Production-tuned settings from Feb 2026
// This is the "dial it to 11" config — everything tuned for power users who want
// maximum capability with smart safety rails. Running in production daily.
//
// Why OpenClaw ships conservative by default:
// - Most users want "just works" over "maximum power"
// - Aggressive settings can be confusing during initial setup
// - Provider rate limits vary wildly per user
//
// This config represents 60% → 100% — unlocking features that are stable but
// require understanding what they do. Not "experimental" — just "enthusiast."

{
  // Auth & provider reliability
  auth: {
    cooldowns: {
      billingBackoffHours: 2,    // Wait 2h before retrying after billing error
      billingMaxHours: 12,       // Max 12h of backoff total
      failureWindowHours: 12     // Track failures over 12h window
    }
  },

  // Cron job management
  cron: {
    maxConcurrentRuns: 3         // Allow 3 cron jobs to run simultaneously
  },

  agents: {
    defaults: {
      // Subagent lifecycle — clean up after 1 hour
      subagents: {
        archiveAfterMinutes: 60  // Production: archive subagents after 60min idle
      },

      // Default thinking mode
      thinkingDefault: "low",    // Low thinking for speed, use /reasoning when needed

      // Request timeout
      timeoutSeconds: 300        // 5-minute timeout for long-running operations
    }
  },

  // Tool optimizations
  tools: {
    web: {
      search: {
        cacheTtlMinutes: 15      // Cache search results for 15 minutes
      },
      fetch: {
        cacheTtlMinutes: 10      // Cache fetched pages for 10 minutes
      }
    }
  },

  // Message handling
  messages: {
    removeAckAfterReply: true    // Clean up 👀 reactions after replying
  },

  // Discord-specific
  channels: {
    discord: {
      replyToMode: "first"       // Reply to the first message in a thread, not last
    }
  },

  // Logging
  logging: {
    redactSensitive: "tools"     // Redact sensitive data in tool call logs
  },

  // Session management — longer idle time for Discord
  session: {
    resetByChannel: {
      discord: {
        mode: "idle",
        idleMinutes: 720         // 12-hour idle timeout (vs 24h default)
      }
    }
  }
}
